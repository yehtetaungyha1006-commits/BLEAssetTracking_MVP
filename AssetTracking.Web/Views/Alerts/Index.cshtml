@model IEnumerable<AlertLog>
@{
    ViewData["Title"] = "System Alerts Log";
    var search = ViewBag.Search as string;
    var currentAlertType = ViewBag.AlertType as string;
    var currentSeverity = ViewBag.Severity as string;
    var currentStatus = ViewBag.Status as string;
    var alertTypes = ViewBag.AlertTypes as List<string> ?? new List<string>();
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int totalItems = ViewBag.TotalItems;
}

<style>
    .alerts-header h2 {
        font-weight: 700;
        font-size: 1.75rem;
        background: linear-gradient(to right, #ffffff, #cbd5e1) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
    }

    .filter-card {
        background-color: var(--card-bg) !important;
        border: 1px solid var(--border-color) !important;
        border-radius: 0.75rem;
        padding: 1.25rem;
        margin-bottom: 1.5rem;
    }

    .pagination-custom .page-link {
        background-color: rgba(255, 255, 255, 0.03) !important;
        border-color: var(--border-color) !important;
        color: #cbd5e1 !important;
        transition: all 0.2s ease;
    }

    .pagination-custom .page-link:hover {
        background-color: rgba(255, 255, 255, 0.1) !important;
        color: #ffffff !important;
        border-color: rgba(255, 255, 255, 0.25) !important;
    }

    .pagination-custom .page-item-prev-next .page-link {
        background-color: transparent !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        color: #cbd5e1 !important;
    }

    .pagination-custom .page-item-prev-next .page-link:hover {
        background-color: rgba(255, 255, 255, 0.05) !important;
        color: #ffffff !important;
        border-color: rgba(255, 255, 255, 0.4) !important;
    }

    .pagination-custom .page-item.active .page-link {
        background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%) !important;
        border-color: transparent !important;
        color: #ffffff !important;
    }

    .pagination-custom .page-item.disabled {
        opacity: 0.4;
        pointer-events: none;
    }

    .pagination-custom .page-item.disabled .page-link {
        background-color: transparent !important;
        border-color: var(--border-color) !important;
        color: #64748b !important;
    }

    /* Severity badges (text only) */
    .badge-severity {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 0.35rem 0.75rem;
        border-radius: 0.375rem;
        display: inline-block;
    }

    .badge-severity-critical {
        background-color: rgba(239, 68, 68, 0.12) !important;
        color: #f87171 !important;
        border: 1px solid rgba(239, 68, 68, 0.2) !important;
    }

    .badge-severity-warning {
        background-color: rgba(245, 158, 11, 0.12) !important;
        color: #fbbf24 !important;
        border: 1px solid rgba(245, 158, 11, 0.2) !important;
    }

    .badge-severity-info {
        background-color: rgba(59, 130, 246, 0.12) !important;
        color: #60a5fa !important;
        border: 1px solid rgba(59, 130, 246, 0.2) !important;
    }

    /* Status badges (text only) */
    .badge-status {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 0.35rem 0.75rem;
        border-radius: 0.375rem;
        display: inline-block;
    }

    .badge-status-active {
        background-color: rgba(244, 63, 94, 0.12) !important;
        color: #fb7185 !important;
        border: 1px solid rgba(244, 63, 94, 0.2) !important;
    }

    .badge-status-resolved {
        background-color: rgba(16, 185, 129, 0.12) !important;
        color: #34d399 !important;
        border: 1px solid rgba(16, 185, 129, 0.2) !important;
    }

    .mac-address {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: #94a3b8;
    }

    .device-name {
        font-weight: 600;
        color: #ffffff;
    }

    .alert-time {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: #cbd5e1;
    }

    .alert-msg {
        color: #f8fafc;
    }

    .alert-row-clickable {
        cursor: pointer;
        transition: background-color 0.15s ease;
    }

    .alert-row-clickable:hover {
        background-color: rgba(255, 255, 255, 0.05) !important;
    }

    .badge-alert-type {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.65rem;
        font-size: 0.8rem;
        font-weight: 600;
        border-radius: 6px;
    }
    
    .badge-alert-type.critical {
        background-color: rgba(239, 68, 68, 0.12) !important;
        color: #f87171 !important;
        border: 1px solid rgba(239, 68, 68, 0.2) !important;
    }
    
    .badge-alert-type.warning {
        background-color: rgba(245, 158, 11, 0.12) !important;
        color: #fbbf24 !important;
        border: 1px solid rgba(245, 158, 11, 0.2) !important;
    }
    
    .badge-alert-type.info {
        background-color: rgba(59, 130, 246, 0.12) !important;
        color: #60a5fa !important;
        border: 1px solid rgba(59, 130, 246, 0.2) !important;
    }
</style>

<div class="container-fluid">
    <div class="alerts-header mb-4">
        <h2>System Alerts Log</h2>
        <p class="text-muted mb-0">Review anomalies, warnings, and recovery event logs across the system.</p>
    </div>

    <!-- Filters Panel -->
    <div class="filter-card">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="label-custom form-label mb-2" for="search">Search Keywords</label>
                <input type="text" id="search" name="search" class="form-control input-custom" value="@search" placeholder="Device Name, MAC, Scanner ID" />
            </div>
            
            <div class="col-md-3">
                <label class="label-custom form-label mb-2" for="alertType">Alert Type</label>
                <select id="alertType" name="alertType" class="form-select input-custom">
                    <option value="">All Types</option>
                    @foreach (var type in alertTypes)
                    {
                        if (type == currentAlertType)
                        {
                            <option value="@type" selected>@type</option>
                        }
                        else
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="label-custom form-label mb-2" for="severity">Severity</label>
                <select id="severity" name="severity" class="form-select input-custom">
                    <option value="">All Severities</option>
                    <!---->
                    @if (currentSeverity == "Info") { <option value="Info" selected>Info</option> } else { <option value="Info">Info</option> }
                    @if (currentSeverity == "Warning") { <option value="Warning" selected>Warning</option> } else { <option value="Warning">Warning</option> }
                    @if (currentSeverity == "Critical") { <option value="Critical" selected>Critical</option> } else { <option value="Critical">Critical</option> }
                </select>
            </div>

            <div class="col-md-2">
                <label class="label-custom form-label mb-2" for="status">Status</label>
                <select id="status" name="status" class="form-select input-custom">
                    <option value="">All Statuses</option>
                    <!---->
                    @if (currentStatus == "Active") { <option value="Active" selected>Active</option> } else { <option value="Active">Active</option> }
                    @if (currentStatus == "Resolved") { <option value="Resolved" selected>Resolved</option> } else { <option value="Resolved">Resolved</option> }
                </select>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1 py-2">
                    Apply Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-light py-2 px-3" title="Clear filters">
                    Reset
                </a>
            </div>
        </form>
    </div>

    <!-- Table Card -->
    <div class="card card-custom mb-4">
        <div class="table-responsive">
            <table class="table table-custom mb-0">
                <thead>
                    <tr>
                        <th style="width: 20%;">Time</th>
                        <th style="width: 25%;">Device</th>
                        <th style="width: 40%;">Alert</th>
                        <th style="width: 15%;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                No matching alerts found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var alert in Model)
                        {
                            string severityClass = alert.Severity switch
                            {
                                "Critical" => "critical",
                                "Warning" => "warning",
                                "Info" or _ => "info"
                            };

                            string statusClass = alert.IsResolved ? "badge-status-resolved" : "badge-status-active";
                            string statusText = alert.IsResolved ? "Resolved" : "Active";
                            string scannerText = alert.ScannerId ?? "-";
                            string deviceName = alert.Device?.DeviceName ?? alert.Device?.MacAddress ?? "-";
                            string relativeTime = AssetTracking.Web.Helpers.DateTimeHelper.FormatLastSeen(alert.AlertTime);
                            string lastSeenStr = alert.Device?.LastSeen.HasValue == true 
                                ? AssetTracking.Web.Helpers.DateTimeHelper.FormatLastSeen(alert.Device.LastSeen) 
                                : "Never";

                            <tr class="alert-row-clickable" 
                                data-bs-toggle="modal" 
                                data-bs-target="#alertDetailModal"
                                data-device-name="@(alert.Device?.DeviceName ?? "Unnamed Device")"
                                data-mac-address="@(alert.Device?.MacAddress ?? "-")"
                                data-scanner="@scannerText"
                                data-message="@alert.AlertMessage"
                                data-severity="@alert.Severity"
                                data-last-seen="@lastSeenStr"
                                data-created-time="@alert.AlertTime.ToString("yyyy-MM-dd HH:mm:ss")">
                                <td class="alert-time">@relativeTime</td>
                                <td class="device-name">@deviceName</td>
                                <td>
                                    <span class="badge-alert-type @severityClass">@alert.Severity • @alert.AlertType</span>
                                </td>
                                <td>
                                    <span class="badge-status @statusClass">@statusText</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        var pageElements = new List<string>();
        if (totalPages <= 7)
        {
            for (int i = 1; i <= totalPages; i++)
            {
                pageElements.Add(i.ToString());
            }
        }
        else
        {
            if (currentPage <= 4)
            {
                pageElements.Add("1");
                pageElements.Add("2");
                pageElements.Add("3");
                pageElements.Add("4");
                pageElements.Add("5");
                pageElements.Add("6");
                pageElements.Add("...");
                pageElements.Add(totalPages.ToString());
            }
            else if (currentPage >= totalPages - 3)
            {
                pageElements.Add("1");
                pageElements.Add("...");
                pageElements.Add((totalPages - 5).ToString());
                pageElements.Add((totalPages - 4).ToString());
                pageElements.Add((totalPages - 3).ToString());
                pageElements.Add((totalPages - 2).ToString());
                pageElements.Add((totalPages - 1).ToString());
                pageElements.Add(totalPages.ToString());
            }
            else
            {
                pageElements.Add("1");
                pageElements.Add("...");
                pageElements.Add((currentPage - 2).ToString());
                pageElements.Add((currentPage - 1).ToString());
                pageElements.Add(currentPage.ToString());
                pageElements.Add((currentPage + 1).ToString());
                pageElements.Add((currentPage + 2).ToString());
                pageElements.Add("...");
                pageElements.Add(totalPages.ToString());
            }
        }

        <!-- Desktop Pagination -->
        <nav aria-label="Alert logs pagination" class="d-none d-sm-block">
            <ul class="pagination pagination-custom justify-content-center">
                <!-- Previous Button -->
                <li class="page-item page-item-prev-next @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="?search=@search&alertType=@currentAlertType&severity=@currentSeverity&status=@currentStatus&page=@(currentPage - 1)" aria-label="Previous">
                        &lt;
                    </a>
                </li>

                <!-- Page numbers -->
                @foreach (var elem in pageElements)
                {
                    if (elem == "...")
                    {
                        <li class="page-item disabled"><span class="page-link" style="background-color: transparent !important; border: none !important;">...</span></li>
                    }
                    else
                    {
                        int pVal = int.Parse(elem);
                        <li class="page-item @(currentPage == pVal ? "active" : "")">
                            <a class="page-link" href="?search=@search&alertType=@currentAlertType&severity=@currentSeverity&status=@currentStatus&page=@pVal">@pVal</a>
                        </li>
                    }
                }

                <!-- Next Button -->
                <li class="page-item page-item-prev-next @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="?search=@search&alertType=@currentAlertType&severity=@currentSeverity&status=@currentStatus&page=@(currentPage + 1)" aria-label="Next">
                        &gt;
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Mobile Pagination -->
        <nav aria-label="Alert logs pagination mobile" class="d-block d-sm-none">
            <ul class="pagination pagination-custom justify-content-center align-items-center">
                <!-- Previous Button -->
                <li class="page-item page-item-prev-next @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="?search=@search&alertType=@currentAlertType&severity=@currentSeverity&status=@currentStatus&page=@(currentPage - 1)" aria-label="Previous">
                        &lt;
                    </a>
                </li>

                <li class="px-3 text-muted" style="font-size: 0.9rem; font-weight: 500;">
                    @currentPage / @totalPages
                </li>

                <!-- Next Button -->
                <li class="page-item page-item-prev-next @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="?search=@search&alertType=@currentAlertType&severity=@currentSeverity&status=@currentStatus&page=@(currentPage + 1)" aria-label="Next">
                        &gt;
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<!-- Details Modal -->
<div class="modal fade" id="alertDetailModal" tabindex="-1" aria-labelledby="alertDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; color: #ffffff;">
            <div class="modal-header" style="border-bottom: 1px solid rgba(255, 255, 255, 0.08); padding: 1.25rem;">
                <h5 class="modal-title fw-bold" id="alertDetailModalLabel" style="font-size: 1.15rem;">Alert Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <table class="table table-borderless text-white mb-0" style="font-size: 0.95rem;">
                    <tbody>
                        <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                            <td class="text-muted py-2.5" style="width: 35%;">Device Name</td>
                            <td id="modal-device-name" class="fw-semibold py-2.5"></td>
                        </tr>
                        <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                            <td class="text-muted py-2.5">MAC Address</td>
                            <td id="modal-mac-address" class="font-monospace py-2.5"></td>
                        </tr>
                        <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                            <td class="text-muted py-2.5">Scanner</td>
                            <td id="modal-scanner" class="py-2.5"></td>
                        </tr>
                        <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                            <td class="text-muted py-2.5">Severity</td>
                            <td class="py-2.5"><span id="modal-severity" class="badge"></span></td>
                        </tr>
                        <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                            <td class="text-muted py-2.5">Last Seen</td>
                            <td id="modal-last-seen" class="py-2.5"></td>
                        </tr>
                        <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                            <td class="text-muted py-2.5">Created Time</td>
                            <td id="modal-created-time" class="font-monospace py-2.5"></td>
                        </tr>
                        <tr>
                            <td class="text-muted py-3">Message</td>
                            <td id="modal-message" class="py-3" style="white-space: pre-wrap; line-height: 1.5; color: #e2e8f0;"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer" style="border-top: 1px solid rgba(255, 255, 255, 0.08); padding: 1rem 1.25rem;">
                <button type="button" class="btn btn-outline-light btn-sm px-4" data-bs-dismiss="modal" style="border-radius: 6px; font-weight: 600;">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const detailModal = document.getElementById('alertDetailModal');
        if (detailModal) {
            detailModal.addEventListener('show.bs.modal', function (event) {
                const row = event.relatedTarget;
                
                document.getElementById('modal-device-name').innerText = row.getAttribute('data-device-name');
                document.getElementById('modal-mac-address').innerText = row.getAttribute('data-mac-address');
                document.getElementById('modal-scanner').innerText = row.getAttribute('data-scanner');
                document.getElementById('modal-message').innerText = row.getAttribute('data-message');
                document.getElementById('modal-severity').innerText = row.getAttribute('data-severity');
                document.getElementById('modal-last-seen').innerText = row.getAttribute('data-last-seen');
                document.getElementById('modal-created-time').innerText = row.getAttribute('data-created-time');

                // Adjust severity badge color in modal
                const severity = row.getAttribute('data-severity') || 'Info';
                const badge = document.getElementById('modal-severity');
                badge.className = 'badge';
                if (severity === 'Critical') {
                    badge.classList.add('bg-danger');
                } else if (severity === 'Warning') {
                    badge.classList.add('bg-warning', 'text-dark');
                } else {
                    badge.classList.add('bg-info');
                }
            });
        }
    });
</script>
