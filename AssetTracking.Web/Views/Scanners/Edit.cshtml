@model ScannerDevice
@{
    ViewData["Title"] = "Edit Scanner";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
    .edit-scanner-container {
        font-family: 'Outfit', sans-serif;
        color: #1e293b;
        margin-top: 1.5rem;
        max-width: 650px;
    }

    .edit-header h2 {
        font-weight: 700;
        font-size: 1.75rem;
        background: linear-gradient(135deg, #1e293b 0%, #475569 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.5rem;
    }

    .edit-header p {
        color: #64748b;
        font-size: 0.95rem;
    }

    .card-form {
        border: none;
        border-radius: 1rem;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        background-color: #ffffff;
        border: 1px solid #f1f5f9;
        padding: 2rem;
    }

    .form-group-custom {
        margin-bottom: 1.5rem;
    }

    .label-custom {
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #475569;
        margin-bottom: 0.5rem;
        display: block;
    }

    .input-custom {
        border-radius: 0.5rem;
        border: 1px solid #cbd5e1;
        padding: 0.6rem 0.9rem;
        font-size: 0.95rem;
        transition: all 0.2s ease;
        color: #334155;
    }

    .input-custom:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        outline: none;
    }

    .input-readonly {
        background-color: #f8fafc;
        border-color: #e2e8f0;
        color: #64748b;
        cursor: not-allowed;
    }

    .input-readonly:focus {
        box-shadow: none;
        border-color: #e2e8f0;
    }

    .validation-error {
        font-size: 0.85rem;
        color: #dc2626;
        margin-top: 0.35rem;
        font-weight: 500;
        display: block;
    }

    .btn-save {
        background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
        color: #ffffff;
        font-weight: 600;
        border: none;
        border-radius: 0.5rem;
        padding: 0.6rem 1.5rem;
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }

    .btn-save:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
        color: #ffffff;
    }

    .btn-cancel {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: 600;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 0.6rem 1.5rem;
        font-size: 0.95rem;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

    .btn-cancel:hover {
        background-color: #e2e8f0;
        color: #1e293b;
    }

    .readonly-badge {
        font-size: 0.7rem;
        font-weight: 700;
        color: #64748b;
        background-color: #f1f5f9;
        padding: 0.15rem 0.4rem;
        border-radius: 0.25rem;
        margin-left: 0.5rem;
        text-transform: uppercase;
    }
</style>

<div class="edit-scanner-container container">
    <div class="edit-header mb-4">
        <h2>Edit Scanner Details</h2>
        <p>Modify receiver properties. Read-only fields cannot be altered from this panel.</p>
    </div>

    <div class="card-form">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Hidden input for ScannerId to bind properly on post -->
            <input type="hidden" asp-for="ScannerId" />

            <div class="form-group-custom">
                <label class="label-custom">
                    Scanner ID
                    <span class="readonly-badge">Read-Only</span>
                </label>
                <input asp-for="ScannerId" class="form-control input-custom input-readonly" readonly />
            </div>

            <div class="form-group-custom">
                <label class="label-custom" asp-for="ScannerName">Scanner Name</label>
                <input asp-for="ScannerName" class="form-control input-custom" placeholder="e.g. Scanner 01" />
                <span asp-validation-for="ScannerName" class="validation-error"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group-custom">
                        <label class="label-custom" asp-for="Building">Building</label>
                        <input asp-for="Building" class="form-control input-custom" placeholder="e.g. HQ Building" />
                        <span asp-validation-for="Building" class="validation-error"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group-custom">
                        <label class="label-custom" asp-for="Floor">Floor</label>
                        <input asp-for="Floor" class="form-control input-custom" placeholder="e.g. 1st Floor" />
                        <span asp-validation-for="Floor" class="validation-error"></span>
                    </div>
                </div>
            </div>

            <div class="form-group-custom">
                <label class="label-custom" asp-for="Location">Location/Room</label>
                <input asp-for="Location" class="form-control input-custom" placeholder="e.g. Conference Room A" />
                <span asp-validation-for="Location" class="validation-error"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group-custom">
                        <label class="label-custom">
                            Current Status
                            <span class="readonly-badge">Read-Only</span>
                        </label>
                        <input asp-for="Status" class="form-control input-custom input-readonly" readonly />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group-custom">
                        <label class="label-custom">
                            Last Seen
                            <span class="readonly-badge">Read-Only</span>
                        </label>
                        <input value="@AssetTracking.Web.Helpers.DateTimeHelper.FormatLastSeen(Model.LastSeen)" class="form-control input-custom input-readonly" readonly />
                    </div>
                </div>
            </div>

            <div class="form-group-custom">
                <label class="label-custom">
                    Created At
                    <span class="readonly-badge">Read-Only</span>
                </label>
                <input value="@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")" class="form-control input-custom input-readonly" readonly />
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <a asp-action="Index" class="btn-cancel">
                    Cancel
                </a>
                <button type="submit" class="btn btn-save">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
