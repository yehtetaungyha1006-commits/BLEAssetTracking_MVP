@model ScannerDevice
@{
    ViewData["Title"] = "Delete Scanner";
    bool hasRecentTelemetry = ViewBag.HasRecentTelemetry ?? false;
}

<style>
    .delete-container {
        max-width: 650px;
        margin-top: 1.5rem;
    }

    .delete-header h2 {
        font-weight: 700;
        font-size: 1.75rem;
        background: linear-gradient(to right, #ffffff, #cbd5e1) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
    }

    .delete-card {
        background-color: var(--card-bg) !important;
        border: 1px solid var(--border-color) !important;
        border-radius: 1rem;
        padding: 2rem;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 0.85rem 0;
        border-bottom: 1px solid var(--border-color);
    }

    .detail-label {
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05em;
    }

    .detail-value {
        color: var(--text-main);
        font-weight: 500;
    }

    .scanner-id-val {
        font-family: 'JetBrains Mono', monospace;
        color: #cbd5e1;
    }

    .warning-box {
        background-color: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #f87171;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
    }

    .btn-delete-action {
        background: linear-gradient(135deg, #e11d48 0%, #f43f5e 100%) !important;
        border: none !important;
        color: #ffffff !important;
        font-weight: 600;
        border-radius: 0.5rem;
        padding: 0.6rem 1.5rem;
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }

    .btn-delete-action:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(244, 63, 94, 0.2);
    }

    .btn-delete-action:disabled {
        background: #334155 !important;
        color: #64748b !important;
        cursor: not-allowed;
    }
</style>

<div class="delete-container container">
    <div class="delete-header mb-4">
        <h2>Delete Scanner</h2>
        <p class="text-muted">Are you sure you want to delete this scanner device?</p>
    </div>

    <div class="delete-card">
        @if (hasRecentTelemetry)
        {
            <div class="warning-box">
                <strong>Action Blocked:</strong> Cannot delete scanner <strong>@Model.ScannerId</strong> because it has detected beacon telemetry in the last 5 minutes.
            </div>
        }
        else
        {
            <div class="alert alert-warning bg-warning-custom border-warning-custom text-warning-custom mb-4" role="alert" style="background-color: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); color: #fbbf24;">
                <strong>Warning:</strong> Deleting this scanner will set the associated historical telemetry records' Scanner field to NULL. This action cannot be undone.
            </div>
        }

        <div class="mb-4">
            <div class="detail-row">
                <span class="detail-label">Scanner ID</span>
                <span class="detail-value scanner-id-val">@Model.ScannerId</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Building</span>
                <span class="detail-value">@Model.Building</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Floor</span>
                <span class="detail-value">@Model.Floor</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Location/Room</span>
                <span class="detail-value">@Model.Location</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Created At</span>
                <span class="detail-value">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="ScannerId" />
            <div class="d-flex justify-content-between align-items-center mt-4">
                <a asp-action="Index" class="btn btn-outline-light px-4 py-2">
                    Cancel
                </a>
                <button type="submit" class="btn btn-delete-action px-4 py-2" @(hasRecentTelemetry ? "disabled" : "")>
                    Delete Scanner
                </button>
            </div>
        </form>
    </div>
</div>
