    /* Battery styles */
    /*.battery-container {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-weight: 500;
    }*/

    .battery-icon {
        font-size: 1.1rem;
    }

    .battery-high { color: #10b981; }
    .battery-medium { color: #f59e0b; }
    .battery-low { color: #ef4444; }

    /* Row highlight animation */
    @@keyframes rowUpdateFlash {
        0% { background-color: rgba(99, 102, 241, 0.2); }
        100% { background-color: transparent; }
    }

    .row-update-flash {
        animation: rowUpdateFlash 0.8s ease-out;
    }
</style>

<div class="container-fluid">
    <div class="live-header mb-4">
        <h2>Live Beacon Tracking</h2>
        <p class="text-muted">Real-time mapping of BLE beacons and their nearest scanner positions.</p>
    </div>

    <!-- Metrics Cards -->
    <div class="metrics-grid-live">
        <div class="metric-card-live">
            <div class="metric-icon-live metric-icon-total">
                <i class="bi bi-broadcast"></i>
            </div>
            <div>
                <div class="metric-value-live" id="totalBeaconsCount">0</div>
                <div class="metric-label-live">Total Beacons</div>
            </div>
        </div>
        <div class="metric-card-live">
            <div class="metric-icon-live metric-icon-online">
                <i class="bi bi-wifi"></i>
            </div>
            <div>
                <div class="metric-value-live" id="onlineBeaconsCount">0</div>
                <div class="metric-label-live">Online (Seen &le; 30s)</div>
            </div>
        </div>
        <div class="metric-card-live">
            <div class="metric-icon-live metric-icon-offline">
                <i class="bi bi-wifi-off"></i>
            </div>
            <div>
                <div class="metric-value-live" id="offlineBeaconsCount">0</div>
                <div class="metric-label-live">Offline (Inactive)</div>
            </div>
        </div>
    </div>

    <!-- Live Tracking Table -->
    <div class="card card-custom">
        <div class="table-responsive">
            <table class="table table-custom mb-0">
                <thead>
                    <tr>
                        <th>Device Name</th>
                        <th>MAC Address</th>
                        <th>Status</th>
                        <th>Nearest Scanner</th>
                        <th>Building</th>
                        <th>Floor</th>
                        <th>Location</th>
                        <th>RSSI</th>
                        <th>Battery</th>
                        <th>Last Seen</th>
                    </tr>
                </thead>
                <tbody id="liveTrackingBody">
                    <tr>
                        <td colspan="10" class="text-center py-5 text-muted">
                            <div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div>
                            <span class="d-block">Loading real-time beacon metrics...</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const trackingBody = document.getElementById('liveTrackingBody');
        const totalBeaconsCount = document.getElementById('totalBeaconsCount');
        const onlineBeaconsCount = document.getElementById('onlineBeaconsCount');
        const offlineBeaconsCount = document.getElementById('offlineBeaconsCount');

        let deviceDataStore = {};

        function getBatteryMarkup(battery) {
            return `<span style="color: #10B981; font-weight: 500;">${battery}%</span>`;
        }

        function getRssiMarkup(rssi) {
            if (rssi === 0) return `<span class="text-muted">-</span>`;
            return `<span class="text-white">${rssi} dBm</span>`;
        }

        function getRelativeTimeStr(lastSeenStr) {
            if (!lastSeenStr || lastSeenStr === 'Never') return 'Never';
            
            // Format space to T for ISO standard
            let dateStr = lastSeenStr.replace(' ', 'T');
            if (!dateStr.endsWith('Z') && !dateStr.includes('+')) {
                dateStr += 'Z';
            }
            const lastSeenDate = new Date(dateStr);
            if (isNaN(lastSeenDate.getTime())) return 'Never';
            
            const now = new Date();
            const diffMs = now - lastSeenDate;
            const diffSecs = Math.max(0, Math.floor(diffMs / 1000));
            
            if (diffSecs < 10) {
                return 'just now';
            } else if (diffSecs < 60) {
                return `${diffSecs} sec ago`;
            } else if (diffSecs < 3600) {
                const diffMins = Math.floor(diffSecs / 60);
                return `${diffMins} min ago`;
            } else if (diffSecs < 86400) {
                const diffHrs = Math.floor(diffSecs / 3600);
                return `${diffHrs} hr ago`;
            } else if (diffSecs < 604800) {
                const diffDays = Math.floor(diffSecs / 86400);
                return `${diffDays} days ago`;
            } else {
                // yyyy-MM-dd HH:mm
                const yyyy = lastSeenDate.getFullYear();
                const MM = String(lastSeenDate.getMonth() + 1).padStart(2, '0');
                const dd = String(lastSeenDate.getDate()).padStart(2, '0');
                const HH = String(lastSeenDate.getHours()).padStart(2, '0');
                const mm = String(lastSeenDate.getMinutes()).padStart(2, '0');
                return `${yyyy}-${MM}-${dd} ${HH}:${mm}`;
            }
        }

        async function fetchLiveTracking() {
            try {
                const response = await fetch('/LiveTracking/Data');
                if (!response.ok) throw new Error('Network error');
                const data = await response.json();

                let total = data.length;
                let online = 0;
                let offline = 0;

                let rowsHtml = '';

                data.forEach(beacon => {
                    const isOnline = beacon.status.toLowerCase() === 'online';
                    if (isOnline) online++; else offline++;

                    const badgeClass = isOnline ? 'badge-online-custom' : 'badge-offline-custom';
                    const dotClass = isOnline ? 'bg-online-custom' : 'bg-offline-custom';

                    // Track changes to trigger CSS flash animations on cells
                    const key = beacon.macAddress;
                    const prevData = deviceDataStore[key];
                    let flashClass = '';

                    if (prevData) {
                        // Flash row if telemetry changed (e.g. status, RSSI, or scanner changed)
                        if (prevData.status !== beacon.status || 
                            prevData.rssi !== beacon.rssi || 
                            prevData.scannerName !== beacon.scannerName) {
                            flashClass = 'row-update-flash';
                        }
                    }
                    deviceDataStore[key] = beacon;

                    rowsHtml += `<tr class="${flashClass}">
                        <td class="device-name">${beacon.deviceName}</td>
                        <td class="mac-address">${beacon.macAddress}</td>
                        <td>
                            <span class="badge-status ${badgeClass}">
                                <span class="status-dot ${dotClass}"></span>
                                ${beacon.status}
                            </span>
                        </td>
                        <td class="text-white fw-semibold">${beacon.scannerName}</td>
                        <td>${beacon.building}</td>
                        <td>${beacon.floor}</td>
                        <td>${beacon.location}</td>
                        <td>${getRssiMarkup(beacon.rssi)}</td>
                        <td>${getBatteryMarkup(beacon.battery)}</td>
                        <td class="font-monospace text-secondary">${beacon.lastSeen}</td>
                    </tr>`;
                });

                if (total === 0) {
                    rowsHtml = `<tr>
                        <td colspan="10" class="text-center py-5 text-muted">
                            No tracking beacons available.
                        </td>
                    </tr>`;
                }

                trackingBody.innerHTML = rowsHtml;
                totalBeaconsCount.innerText = total;
                onlineBeaconsCount.innerText = online;
                offlineBeaconsCount.innerText = offline;

            } catch (err) {
                console.error('Error fetching live tracking metrics:', err);
                trackingBody.innerHTML = `<tr>
                    <td colspan="10" class="text-center py-4 text-danger font-semibold">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Failed to fetch live beacon tracking updates. Retrying...
                    </td>
                </tr>`;
            }
        }

        // Initial fetch
        fetchLiveTracking();

        // Polling every 5 seconds
        setInterval(fetchLiveTracking, 5000);
    </script>
}
