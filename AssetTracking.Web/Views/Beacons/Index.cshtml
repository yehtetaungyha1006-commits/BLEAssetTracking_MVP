@model IEnumerable<BeaconDevice>
@{
    ViewData["Title"] = "Beacon Management";
}



<style>
    .beacons-header h2 {
        font-weight: 700;
        font-size: 1.75rem;
        background: linear-gradient(to right, #ffffff, #cbd5e1) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
    }

    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem 0.75rem;
        font-size: 0.75rem;
        font-weight: 600;
        border-radius: 9999px;
        text-transform: uppercase;
        letter-spacing: 0.025em;
    }

    .badge-online-custom {
        background-color: rgba(16, 185, 129, 0.12) !important;
        color: #34d399 !important;
        border: 1px solid rgba(16, 185, 129, 0.2) !important;
    }

    .badge-offline-custom {
        background-color: rgba(239, 68, 68, 0.12) !important;
        color: #f87171 !important;
        border: 1px solid rgba(239, 68, 68, 0.2) !important;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        display: inline-block;
    }

    .bg-online-custom {
        background-color: #10b981 !important;
    }

    .bg-offline-custom {
        background-color: #ef4444 !important;
    }

    .scanner-id {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: #94a3b8;
        font-weight: 500;
    }

    .scanner-name {
        font-weight: 600;
        color: #ffffff;
    }
</style>

<div class="scanners-container container-fluid">
    <div class="beacons-header mb-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2>Beacon Device Management</h2>
            <p class="text-muted mb-0">Register, monitor, and configure BLE tracking beacons.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary d-inline-flex align-items-center gap-2 px-4 py-2">
                <i class="bi bi-plus-circle"></i> Add Beacon
            </a>
        </div>
    </div>

    <div class="card card-custom">
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>Device Name</th>
                        <th>MAC Address</th>
                        <th>Major</th>
                        <th>Minor</th>
                        <th>Status</th>
                        <th>Last Seen</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="mb-3 d-block mx-auto text-secondary">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                                </svg>
                                No beacons registered in the system.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var beacon in Model)
                        {
                            bool isOnline = beacon.Status != null && beacon.Status.Equals("Online", StringComparison.OrdinalIgnoreCase);
                            string badgeClass = isOnline ? "badge-online-custom" : "badge-offline-custom";
                            string dotClass = isOnline ? "bg-online-custom" : "bg-offline-custom";

                            <tr>
                                <td class="scanner-name">@(beacon.DeviceName ?? "Unnamed Beacon")</td>
                                <td class="scanner-id">@beacon.MacAddress</td>
                                <td>@beacon.Major</td>
                                <td>@beacon.Minor</td>
                                <td>
                                    <span class="badge-status @badgeClass">
                                        <span class="status-dot @dotClass"></span>
                                        @(beacon.Status ?? "Offline")
                                    </span>
                                </td>
                                <td>@AssetTracking.Web.Helpers.DateTimeHelper.FormatLastSeen(beacon.LastSeen)</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@beacon.DeviceId" class="btn btn-outline-info btn-sm px-3" style="border-radius: 0.5rem; font-weight: 600;">
                                            Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@beacon.DeviceId" class="btn btn-outline-danger btn-sm px-3" style="border-radius: 0.5rem; font-weight: 600;">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
