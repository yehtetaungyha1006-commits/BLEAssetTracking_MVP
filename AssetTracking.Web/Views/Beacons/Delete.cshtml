@model BeaconDevice
@{
    ViewData["Title"] = "Delete Beacon";
}

<div class="edit-scanner-container container">
    <div class="edit-header mb-4">
        <h2>Delete Beacon</h2>
        <p class="text-danger fw-semibold">Are you sure you want to delete this beacon? This action is permanent and cannot be undone.</p>
    </div>

    <div class="card-form border border-danger-subtle">
        <h4 class="text-white mb-4">Beacon Details</h4>
        
        <div class="row mb-3">
            <div class="col-sm-4 text-muted label-custom">Device ID</div>
            <div class="col-sm-8 text-white font-monospace">@Model.DeviceId</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-4 text-muted label-custom">Device Name</div>
            <div class="col-sm-8 text-white fw-bold">@(Model.DeviceName ?? "Unnamed Beacon")</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-4 text-muted label-custom">MAC Address</div>
            <div class="col-sm-8 text-white font-monospace">@Model.MacAddress</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-4 text-muted label-custom">Major</div>
            <div class="col-sm-8 text-white">@Model.Major</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-4 text-muted label-custom">Minor</div>
            <div class="col-sm-8 text-white">@Model.Minor</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-4 text-muted label-custom">Status</div>
            <div class="col-sm-8 text-white">
                @{
                    bool isOnline = Model.Status != null && Model.Status.Equals("Online", StringComparison.OrdinalIgnoreCase);
                    string badgeClass = isOnline ? "badge-online" : "badge-offline";
                    string dotClass = isOnline ? "bg-online" : "bg-offline";
                }
                <span class="badge-status @badgeClass">
                    <span class="status-dot @dotClass"></span>
                    @(Model.Status ?? "Offline")
                </span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-4 text-muted label-custom">Last Seen</div>
            <div class="col-sm-8 text-white">@(Model.LastSeen?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")</div>
        </div>

        <div class="row mb-4">
            <div class="col-sm-4 text-muted label-custom">Created At</div>
            <div class="col-sm-8 text-white">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="DeviceId" />
            <div class="d-flex justify-content-between align-items-center mt-4">
                <a asp-action="Index" class="btn-cancel">
                    Cancel
                </a>
                <button type="submit" class="btn btn-danger px-4 py-2" style="border-radius: 0.5rem; font-weight: 600;">
                    Confirm Delete
                </button>
            </div>
        </form>
    </div>
</div>
