@model BeaconDevice
@{
    ViewData["Title"] = "Edit Beacon";
}

<div class="edit-scanner-container container">
    <div class="edit-header mb-4">
        <h2>Edit Beacon Details</h2>
        <p class="text-muted">Modify registered BLE beacon fields. Read-only values cannot be altered.</p>
    </div>

    <div class="card-form">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.9rem; font-weight: 500;"></div>

            <!-- Hidden input for DeviceId to bind properly on post -->
            <input type="hidden" asp-for="DeviceId" />

            <div class="form-group-custom">
                <label class="label-custom">
                    Device ID
                    <span class="readonly-badge">Read-Only</span>
                </label>
                <input asp-for="DeviceId" class="form-control input-custom input-readonly" readonly />
            </div>

            <div class="form-group-custom">
                <label class="label-custom" asp-for="DeviceName">Device Name</label>
                <input asp-for="DeviceName" class="form-control input-custom" placeholder="e.g. Forklift Beacon 04" />
                <span asp-validation-for="DeviceName" class="validation-error"></span>
            </div>

            <div class="form-group-custom">
                <label class="label-custom" asp-for="MacAddress">MAC Address</label>
                <input asp-for="MacAddress" class="form-control input-custom" placeholder="e.g. AA:BB:CC:DD:EE:FF" />
                <span asp-validation-for="MacAddress" class="validation-error"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group-custom">
                        <label class="label-custom" asp-for="Major">Major</label>
                        <input asp-for="Major" type="number" class="form-control input-custom" min="0" />
                        <span asp-validation-for="Major" class="validation-error"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group-custom">
                        <label class="label-custom" asp-for="Minor">Minor</label>
                        <input asp-for="Minor" type="number" class="form-control input-custom" min="0" />
                        <span asp-validation-for="Minor" class="validation-error"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group-custom">
                        <label class="label-custom">
                            Current Status
                            <span class="readonly-badge">Read-Only</span>
                        </label>
                        <input asp-for="Status" class="form-control input-custom input-readonly" readonly />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group-custom">
                        <label class="label-custom">
                            Last Seen
                            <span class="readonly-badge">Read-Only</span>
                        </label>
                        <input value="@AssetTracking.Web.Helpers.DateTimeHelper.FormatLastSeen(Model.LastSeen)" class="form-control input-custom input-readonly" readonly />
                    </div>
                </div>
            </div>

            <div class="form-group-custom">
                <label class="label-custom">
                    Created At
                    <span class="readonly-badge">Read-Only</span>
                </label>
                <input value="@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")" class="form-control input-custom input-readonly" readonly />
            </div>

            <div class="d-flex justify-content-end gap-3 mt-4">
                <a asp-action="Index" class="btn btn-outline-light px-4 py-2">
                    Cancel
                </a>
                <button type="submit" class="btn btn-primary px-4 py-2">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
