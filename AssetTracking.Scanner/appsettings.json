{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ApiSettings": {
    "BaseUrl": "http://localhost:5176"
  },
  "ScannerSettings": {
    "TelemetryIntervalSeconds": 2,
    "OfflineTimeoutSeconds": 30,
    "MinimumRssi": -100,
    "MotionThreshold": 0.15,
    "EnableRawAccFrameLogging": false,
    "MotionDeltaThresholdG": 0.08,
    "MotionHoldSeconds": 3,
    "DiagnosticTargetMac": "C3:00:00:4F:89:CB",
    "EnableBlePacketDiagnostics": true,
    "BleDiagnosticDurationSeconds": 60
  }
}
