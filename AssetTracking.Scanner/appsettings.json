{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ScannerSettings": {
    "Building": "A",
    // Time interval in seconds between sending telemetry reports
    "TelemetryIntervalSeconds": 2,
    // Timeout in seconds before a beacon is considered offline and removed from scanner cache
    "OfflineTimeoutSeconds": 30,
    // Minimum RSSI signal strength (dBm) required for a beacon packet to be processed
    "MinimumRssi": -100,
    // Whether automatic registration of this scanner is enabled on the server
    "EnableAutoRegistration": true
  }
}
